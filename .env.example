# Copy this file to .env.local for local development (vercel dev).
# In production, set these in the Vercel dashboard OR as GitHub Actions secrets.
# Never commit real values.

# REQUIRED — your Anthropic API key, from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — secret used to sign anonymous device tokens.
# If unset, the app falls back to using ANTHROPIC_API_KEY for signing.
# Set a separate random string in production (e.g. run: openssl rand -hex 32).
AUTH_SECRET=

# OPTIONAL — per-device rate limits (sensible defaults applied if unset)
DAILY_LIMIT=60
BURST_LIMIT=8

# OPTIONAL — shared rate limiting across all serverless instances.
# Without these, rate limiting is best-effort per-instance (fine for small scale).
# Create a free Redis database at https://upstash.com and paste its REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Accounts + cross-device sync + analytics (Supabase) ──
# OPTIONAL. Without these the app runs in local-only mode (progress on-device).
# These two are PUBLIC values safe for the browser (row-level security protects data).
# Get them from your Supabase project: Settings → API. See SUPABASE.md.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Operator dashboard (/dashboard) ──
# REQUIRED to open the dashboard. Choose any strong password.
ADMIN_PASSWORD=

# For the dashboard to show REAL analytics (not demo data), it needs to read the
# events table server-side. These are SECRET — never prefix with VITE_, never ship
# to the browser. Get the service_role key from Supabase → Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
